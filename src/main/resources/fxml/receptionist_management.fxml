<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.caresync.controllers.ReceptionistManagementController"
      spacing="18" styleClass="page management-page">
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="4">
            <Label text="Receptionist Management" styleClass="page-title"/>
            <Label text="Manage front desk accounts, contact details, and shift ownership" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER_RIGHT" spacing="3" styleClass="panel-quiet">
            <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
            <Label text="Front Desk" styleClass="stat-label"/>
            <Label text="Patient flow" style="-fx-font-weight: 900; -fx-text-fill: #a66813;"/>
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2">
                    <Label text="Receptionists" styleClass="section-title"/>
                    <Label text="Select a receptionist to update account and shift details" styleClass="muted"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="New Receptionist" onAction="#clearForm" styleClass="secondary-button"/>
            </HBox>
            <TableView fx:id="receptionistTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="260"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="170"/>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="260"/>
                    <TableColumn fx:id="shiftColumn" text="Shift" prefWidth="170"/>
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="12" minWidth="360" prefWidth="390" styleClass="panel form-panel">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <VBox spacing="3">
                <Label text="Receptionist Profile" styleClass="section-title"/>
                <Label text="Login and contact information" styleClass="muted"/>
            </VBox>
            <VBox spacing="10" styleClass="form-section">
                <Label text="Account" styleClass="stat-label"/>
                <TextField fx:id="fullNameField" promptText="Full name"/>
                <TextField fx:id="usernameField" promptText="Username"/>
                <PasswordField fx:id="passwordField" promptText="Password"/>
            </VBox>
            <VBox spacing="10" styleClass="form-section">
                <Label text="Contact and Shift" styleClass="stat-label"/>
                <TextField fx:id="phoneField" promptText="Phone"/>
                <TextField fx:id="emailField" promptText="Email"/>
                <TextField fx:id="shiftField" promptText="Shift"/>
            </VBox>
            <HBox spacing="8">
                <Button text="Save Receptionist" onAction="#saveReceptionist" styleClass="primary-button"/>
                <Button text="Clear" onAction="#clearForm" styleClass="secondary-button"/>
            </HBox>
            <Label fx:id="statusLabel" wrapText="true"/>
        </VBox>
    </HBox>
</VBox>
