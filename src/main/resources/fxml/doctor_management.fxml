<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.caresync.controllers.DoctorManagementController"
      spacing="18" styleClass="page management-page">
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="4">
            <Label text="Doctor Management" styleClass="page-title"/>
            <Label text="Maintain clinical staff accounts, rooms, specialties, and availability" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER_RIGHT" spacing="3" styleClass="panel-quiet">
            <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
            <Label text="Roster" styleClass="stat-label"/>
            <Label text="Clinical coverage" style="-fx-font-weight: 900; -fx-text-fill: #5267d8;"/>
        </VBox>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2">
                    <Label text="Doctors" styleClass="section-title"/>
                    <Label text="Select a doctor to update login and clinical profile details" styleClass="muted"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="New Doctor" onAction="#clearForm" styleClass="secondary-button"/>
            </HBox>
            <TableView fx:id="doctorTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="260"/>
                    <TableColumn fx:id="specialtyColumn" text="Specialization" prefWidth="220"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="160"/>
                    <TableColumn fx:id="availabilityColumn" text="Availability" prefWidth="260"/>
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="12" minWidth="382" prefWidth="410" styleClass="panel form-panel">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <VBox spacing="3">
                <Label text="Doctor Profile" styleClass="section-title"/>
                <Label text="Login details and appointment visibility" styleClass="muted"/>
            </VBox>
            <VBox spacing="10" styleClass="form-section">
                <Label text="Account" styleClass="stat-label"/>
                <TextField fx:id="fullNameField" promptText="Full name"/>
                <TextField fx:id="usernameField" promptText="Username"/>
                <PasswordField fx:id="passwordField" promptText="Password"/>
            </VBox>
            <VBox spacing="10" styleClass="form-section">
                <Label text="Clinical Profile" styleClass="stat-label"/>
                <TextField fx:id="specializationField" promptText="Specialization"/>
                <TextField fx:id="phoneField" promptText="Phone"/>
                <TextField fx:id="emailField" promptText="Email"/>
                <HBox spacing="8">
                    <TextField fx:id="roomField" promptText="Room" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="availabilityField" promptText="Availability" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            <VBox spacing="8" styleClass="availability-builder">
                <Label text="Availability Builder" styleClass="stat-label"/>
                <HBox spacing="6">
                    <CheckBox fx:id="mondayCheck" text="Mon" styleClass="day-check"/>
                    <CheckBox fx:id="tuesdayCheck" text="Tue" styleClass="day-check"/>
                    <CheckBox fx:id="wednesdayCheck" text="Wed" styleClass="day-check"/>
                    <CheckBox fx:id="thursdayCheck" text="Thu" styleClass="day-check"/>
                    <CheckBox fx:id="fridayCheck" text="Fri" styleClass="day-check"/>
                    <CheckBox fx:id="saturdayCheck" text="Sat" styleClass="day-check"/>
                    <CheckBox fx:id="sundayCheck" text="Sun" styleClass="day-check"/>
                </HBox>
                <HBox spacing="8">
                    <TextField fx:id="availabilityStartField" promptText="09:00" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="availabilityEndField" promptText="15:00" HBox.hgrow="ALWAYS"/>
                    <Button text="Apply" onAction="#applyAvailabilityBuilder" styleClass="secondary-button"/>
                </HBox>
            </VBox>
            <HBox spacing="8">
                <Button text="Save Doctor" onAction="#saveDoctor" styleClass="primary-button"/>
                <Button text="Clear" onAction="#clearForm" styleClass="secondary-button"/>
            </HBox>
            <Label fx:id="statusLabel" wrapText="true"/>
        </VBox>
    </HBox>
</VBox>
