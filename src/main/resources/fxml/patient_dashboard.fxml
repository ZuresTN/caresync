<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.caresync.controllers.PatientDashboardController"
      spacing="18" styleClass="page">
    <Label text="Patient Dashboard" styleClass="page-title"/>
    <VBox spacing="8" styleClass="panel">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
        <Label fx:id="profileLabel" text="Patient profile" styleClass="section-title"/>
        <Label fx:id="nextReminderLabel" text="No appointment reminders yet." wrapText="true"/>
        <ProgressBar fx:id="reminderProgress" maxWidth="Infinity"/>
    </VBox>
    <HBox spacing="14">
        <VBox spacing="6" styleClass="stat-card">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <Label text="Appointments" styleClass="muted"/>
            <Label fx:id="appointmentCountLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox spacing="6" styleClass="stat-card">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <Label text="Medical Records" styleClass="muted"/>
            <Label fx:id="historyCountLabel" text="0" styleClass="stat-value"/>
        </VBox>
    </HBox>
    <HBox spacing="14" VBox.vgrow="ALWAYS">
        <VBox spacing="10" styleClass="panel" HBox.hgrow="ALWAYS">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <Label text="Appointments" styleClass="section-title"/>
            <TableView fx:id="appointmentTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="doctorColumn" text="Doctor" prefWidth="220"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="130"/>
                    <TableColumn fx:id="timeColumn" text="Time" prefWidth="120"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="130"/>
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="10" styleClass="panel" HBox.hgrow="ALWAYS">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Medical History" styleClass="section-title"/>
                <Button text="Medical Report PDF" onAction="#generatePrescriptionPdf" styleClass="primary-button"/>
            </HBox>
            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="diagnosisColumn" text="Diagnosis" prefWidth="220"/>
                    <TableColumn fx:id="historyDoctorColumn" text="Doctor" prefWidth="180"/>
                    <TableColumn fx:id="historyDateColumn" text="Date" prefWidth="160"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>
    <Label fx:id="statusLabel" wrapText="true"/>
</VBox>
