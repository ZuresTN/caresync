<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.caresync.controllers.AuditLogController"
      spacing="18" styleClass="page">
    <Label text="Audit Logs" styleClass="page-title"/>
    <HBox spacing="10">
        <TextField fx:id="actionField" promptText="Action" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="entityField" promptText="Entity" HBox.hgrow="ALWAYS"/>
        <TextField fx:id="actorField" promptText="Actor" HBox.hgrow="ALWAYS"/>
        <DatePicker fx:id="datePicker" prefWidth="150"/>
        <Button text="Clear" onAction="#clearFilters" styleClass="secondary-button"/>
    </HBox>
    <VBox spacing="10" styleClass="panel" VBox.vgrow="ALWAYS">
        <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
        <TableView fx:id="auditTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="createdColumn" text="Created" prefWidth="170"/>
                <TableColumn fx:id="actorColumn" text="Actor" prefWidth="180"/>
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="150"/>
                <TableColumn fx:id="entityColumn" text="Entity" prefWidth="150"/>
                <TableColumn fx:id="summaryColumn" text="Summary" prefWidth="420"/>
            </columns>
        </TableView>
        <Label fx:id="statusLabel" wrapText="true"/>
    </VBox>
</VBox>
