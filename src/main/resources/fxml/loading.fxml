<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import java.lang.Double?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.caresync.controllers.LoadingController"
           prefWidth="1080" prefHeight="720" styleClass="loading-root">
    <VBox fx:id="loadingContent" alignment="CENTER" spacing="18">
        <StackPane prefWidth="150" prefHeight="150">
            <Circle fx:id="ringOuter" radius="58" fill="TRANSPARENT" stroke="#d9f2f4" strokeWidth="5">
                <strokeDashArray>
                    <Double fx:value="18"/>
                    <Double fx:value="10"/>
                </strokeDashArray>
            </Circle>
            <Circle fx:id="ringInner" radius="34" fill="TRANSPARENT" stroke="#f2a65a" strokeWidth="4">
                <strokeDashArray>
                    <Double fx:value="12"/>
                    <Double fx:value="8"/>
                </strokeDashArray>
            </Circle>
        </StackPane>
        <Label text="Opening workspace" styleClass="brand-title"/>
        <Label text="Loading your dashboard..." styleClass="brand-subtitle"/>
    </VBox>
    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>
</StackPane>
