<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.caresync.controllers.MedicalRecordController"
      spacing="18" styleClass="page management-page">
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="4">
            <Label text="Medical Records" styleClass="page-title"/>
            <Label text="Clinical notes, diagnosis history, prescription items, and PDF generation" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER_RIGHT" spacing="3" styleClass="panel-quiet">
            <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
            <Label text="Clinical" styleClass="stat-label"/>
            <Label text="Records and PDFs" style="-fx-font-weight: 900; -fx-text-fill: #147f86;"/>
        </VBox>
    </HBox>
    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <VBox spacing="2">
                <Label text="Record Timeline" styleClass="section-title"/>
                <Label text="Filter by patient and select a record for PDF actions" styleClass="muted"/>
            </VBox>
            <TextField fx:id="patientSearchField" promptText="Search patient by name, phone, or email"/>
            <ComboBox fx:id="patientCombo" promptText="Select patient" maxWidth="Infinity"/>
            <TableView fx:id="recordTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="patientColumn" text="Patient" prefWidth="200"/>
                    <TableColumn fx:id="doctorColumn" text="Doctor" prefWidth="200"/>
                    <TableColumn fx:id="diagnosisColumn" text="Diagnosis" prefWidth="260"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="170"/>
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="12" minWidth="400" prefWidth="430" styleClass="panel form-panel">
            <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
            <VBox spacing="3">
                <Label text="Clinical Entry" styleClass="section-title"/>
                <Label text="Capture diagnosis, treatment plan, and prescription details" styleClass="muted" wrapText="true"/>
            </VBox>
            <VBox spacing="10" styleClass="form-section">
                <Label text="Diagnosis" styleClass="stat-label"/>
                <TextField fx:id="diagnosisField" promptText="Diagnosis"/>
                <TextArea fx:id="notesArea" promptText="Treatment notes" prefRowCount="4"/>
            </VBox>
            <VBox spacing="10" styleClass="form-section">
                <Label text="Prescription" styleClass="stat-label"/>
                <TextField fx:id="medicineField" promptText="Medicine"/>
                <TextField fx:id="dosageField" promptText="Dosage"/>
                <HBox spacing="8">
                    <TextField fx:id="frequencyField" promptText="Frequency" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="durationField" promptText="Duration" HBox.hgrow="ALWAYS"/>
                </HBox>
                <TextArea fx:id="instructionsArea" promptText="Instructions" prefRowCount="3"/>
            </VBox>
            <HBox spacing="8">
                <Button text="Save Record" onAction="#saveRecord" styleClass="primary-button"/>
                <Button text="Clear" onAction="#clearForm" styleClass="secondary-button"/>
            </HBox>
            <HBox spacing="8">
                <Button text="Medical Report" onAction="#generateMedicalReportPdf" styleClass="secondary-button"/>
                <Button text="Prescription PDF" onAction="#generatePrescriptionOnlyPdf" styleClass="secondary-button"/>
                <Button text="Full PDF" onAction="#generatePdf" styleClass="secondary-button"/>
            </HBox>
            <HBox spacing="8">
                <Button text="Send PDF" onAction="#sendSelectedPrescriptionPdf" styleClass="secondary-button"/>
            </HBox>
            <Label fx:id="statusLabel" wrapText="true"/>
        </VBox>
    </HBox>
</VBox>
